generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  category    String
  sizes       String
  colors      String
  images      String
  inStock     Boolean  @default(true)
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String
  address      String
  city         String
  postalCode   String
  country      String
  measurements String
  notes        String
  items        String
  total        Float
  status       String   @default("nova")
  createdAt    DateTime @default(now())
}
